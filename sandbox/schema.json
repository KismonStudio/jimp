{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jimp.dev/schemas/sandbox-v1.json",
  "title": "JIMP reference sandbox limits",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "limits"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "unit", "phase", "description"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "value": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
          "unit": { "type": "string", "minLength": 1 },
          "phase": { "enum": ["load", "verify", "execute"] },
          "description": {
            "type": "object",
            "additionalProperties": false,
            "required": ["en", "pt"],
            "properties": {
              "en": { "type": "string", "minLength": 1 },
              "pt": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
