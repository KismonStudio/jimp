{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureon.dev/schemas/isa-v1.json",
  "title": "AUREON portable VM ISA definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "formatVersion",
    "endianness",
    "opcodeWidth",
    "reservedValues",
    "operandTypes",
    "valueTypes",
    "instructions"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "formatVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major", "minor"],
      "properties": {
        "major": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "minor": { "type": "integer", "minimum": 0, "maximum": 65535 }
      }
    },
    "endianness": { "const": "little" },
    "opcodeWidth": { "const": 1 },
    "reservedValues": {
      "type": "object",
      "additionalProperties": false,
      "required": ["noRegister"],
      "properties": {
        "noRegister": { "type": "integer", "minimum": 0, "maximum": 65535 }
      }
    },
    "operandTypes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operandType" }
    },
    "valueTypes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/valueType" }
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/instruction" }
    }
  },
  "$defs": {
    "localizedDescription": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "pt"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "pt": { "type": "string", "minLength": 1 }
      }
    },
    "operandType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "encoding", "allowsNoRegister"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "encoding": { "enum": ["u16", "u32"] },
        "allowsNoRegister": { "type": "boolean" }
      }
    },
    "valueType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tag", "runtimeValue", "description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "tag": { "type": "integer", "minimum": 0, "maximum": 255 },
        "runtimeValue": { "type": "boolean" },
        "description": { "$ref": "#/$defs/localizedDescription" }
      }
    },
    "operand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "type": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
      }
    },
    "instruction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "opcode", "operands", "description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "opcode": { "type": "integer", "minimum": 0, "maximum": 255 },
        "operands": {
          "type": "array",
          "items": { "$ref": "#/$defs/operand" }
        },
        "description": { "$ref": "#/$defs/localizedDescription" }
      }
    }
  }
}
